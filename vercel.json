{
  "buildCommand": "",
  "functions": {
    "api/index.js": {
      "memory": 256,
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/(.*)\\.(.*)", "destination": "/$1.$2" },
    { "source": "/(.*)", "destination": "/piyasaai_macai_tuzakradar_v8.html" }
  ]
}
