# PiyasaAI + MaçAI + Tuzak Radar — Gerekli Tüm API Key'ler
# Kopyala: cp .env.example .env (veya Vercel Dashboard -> Environment Variables)
# NOT: Gerçek key'ler asla commit edilmez, Vercel env'e tek tek eklenir.

# Ortam
NODE_ENV=production
API_DOMAIN=https://lila101okey.win
APP_DOMAIN=https://lila101okey.win

# AI API'leri (Vercel'de gizli env)
OPENAI_API_KEY=xxx
GEMINI_API_KEY=xxx
GEMINI_PROJECT_ID=xxx

# Spor verisi
API_FOOTBALL_KEY=xxx
FOOTBALL_DATA_ORG_KEY=xxx
SPORTMONKS_API_TOKEN=xxx

# Piyasa verisi
ALPHA_VANTAGE_KEY=xxx
FINNHUB_API_KEY=xxx
YAHOO_FINANCE_KEY=xxx
YAHOO_FINANCE_HOST=apidojo-yahoo-finance-v1.p.rapidapi.com

# AdMob (genel ID'ler — APK içinde zaten görünür, gizli değildir)
ADMOB_ANDROID_APP_ID=ca-app-pub-6440512201259891~8121881217
ADMOB_REWARDED_UNIT_ID=ca-app-pub-6440512201259891/7187652032
ADMOB_BANNER_UNIT_ID=ca-app-pub-6440512201259891/6892138563

# Shopier PAT (https://shopier.com/api)
SHOPIER_PAT=xxx
